# كلمة سر قاعدة البيانات (غيّرها لأي شيء قوي)
POSTGRES_PASSWORD=changeme-strong-password-here

# مفتاح JWT (32 حرف على الأقل — ولّد بـ: openssl rand -base64 48)
HN_JWT_SECRET=replace-with-random-32-plus-character-string-here

# الدومين (اتركه فارغاً للعمل على HTTP فقط، أو ضع نطاقك مثل vps.example.com لـ SSL تلقائي)
DOMAIN=

# إعدادات الإيميل (اختياري)
RESEND_API_KEY=
HN_MAIL_FROM=noreply@yourdomain.com
