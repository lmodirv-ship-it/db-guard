# =============================================
# إعدادات بيئة hn-db.online (الإنتاج على VPS)
# انسخ هذا الملف إلى .env وعدّل القيم
# =============================================

# كلمة سر قاعدة البيانات (مهم — ولّد كلمة قوية)
# مثال: openssl rand -base64 24
POSTGRES_PASSWORD=changeme-strong-password-here

# مفتاح JWT لتوقيع الجلسات (32 حرف على الأقل)
# ولّد بـ: openssl rand -base64 48
HN_JWT_SECRET=replace-with-random-48-character-string

# الدومين الإنتاجي
DOMAIN=hn-db.online

# إعدادات الإيميل (لإرسال إيميلات التحقق وإعادة كلمة السر)
RESEND_API_KEY=
HN_MAIL_FROM=noreply@hn-db.online
