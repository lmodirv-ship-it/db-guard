# Database (direct Postgres connection)
HN_DB_URL=postgres://hn:password@127.0.0.1:5432/hn_identity
HN_DB_DIRECT_URL=postgres://hn:password@127.0.0.1:5432/hn_identity

# JWT signing — generate with: openssl rand -hex 32
HN_JWT_SECRET=replace-me

# Email (Resend API or your own SMTP wrapper)
HN_MAIL_FROM="HN Identity <noreply@hnchat.net>"
RESEND_API_KEY=

# Public URL of this DB-GUARD instance (used in email links)
PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase compatibility (leave blank when self-hosting) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
