# Smart Project Generator — required server-side env vars
# All five are MANDATORY. Never expose to the browser (no VITE_ prefix).

# Neon Postgres — pooled (HTTP) connection used by the app
HN_DB_URL="postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Neon Postgres — direct connection used ONLY by the migration runner
HN_DB_DIRECT_URL="postgres://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# JWT signing secret (min 32 chars, random)
HN_JWT_SECRET="replace-with-32-plus-char-random-string"

# Resend API key for transactional email
RESEND_API_KEY="re_xxx"

# Verified sender, e.g. "Smart Generator <noreply@yourdomain.com>"
HN_MAIL_FROM="Smart Generator <noreply@example.com>"
